# ─── Database ───────────────────────────────────────────────
# ⚠️  Replace CHANGE_ME_DB_PASSWORD with a strong random value in production.
#     Generate: openssl rand -hex 24
DATABASE_URL="postgresql://irno:CHANGE_ME_DB_PASSWORD@localhost:5433/irno_hub?schema=public"

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
# ⚠️  Set a strong password in production. Generate: openssl rand -hex 24
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_OR_LEAVE_EMPTY_FOR_LOCAL_DEV

# ─── Auth (Phase 2) ─────────────────────────────────────────
# ⚠️  REQUIRED: Generate unique secrets for each environment.
#     Command: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_openssl_rand_hex_32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ─── Seed credentials (optional — fallback defaults used if not set) ───
# ⚠️  Change these before running the seed in production.
# SUPER_ADMIN_MOBILE=09120000000
# SUPER_ADMIN_EMAIL=admin@irno.ir
# SUPER_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# ─── API ────────────────────────────────────────────────────
API_PORT=4000
# ⚠️  Plural key — API_CORS_ORIGINS (not API_CORS_ORIGIN). Wrong key silently breaks all cross-origin requests.
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ─── Environment ────────────────────────────────────────────
NODE_ENV=development

# ─── hub-web ────────────────────────────────────────────────
# Internal URL from Next.js server components to hub-api (not proxied)
HUB_API_URL=http://localhost:4000
