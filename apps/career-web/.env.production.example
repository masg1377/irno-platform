# ─────────────────────────────────────────────────────────────────────────────
# irno-platform — Career Web — PRODUCTION environment template
#
# Copy to apps/career-web/.env.local and fill in every value before deploying.
#
# ⚠️  NEVER commit the real .env.local file to git.
#
# Build-time vs runtime:
#   Variables prefixed NEXT_PUBLIC_* are baked into the JavaScript bundle at
#   "next build" time. Changing them requires rebuilding the Docker image.
#   Variables without that prefix are read at runtime by Next.js server
#   components — no rebuild required when they change.
# ─────────────────────────────────────────────────────────────────────────────


# ── Hub API URL (server-side, runtime) ───────────────────────────────────────
# Used by career-web server components and route handlers for server-to-server
# calls to hub-api. NOT exposed to the browser.
# In Docker, use the internal compose service name. Career-web and hub-api
# must be on the same Docker network (irno_net) for this to resolve.
HUB_API_URL=http://hub-api:4000


# ── Public URLs (baked at build time — rebuild image if these change) ─────────
# These values are embedded in the client-side JS bundle during "next build".
# ⚠️  If you change any NEXT_PUBLIC_* value, you MUST rebuild the Docker image.

# URL of hub-web (Irno ID hosted login, register, SSO routes).
# Used by career-web to build auth redirect links.
NEXT_PUBLIC_HUB_WEB_URL=https://platform.irnocollege.com

# Public URL of career-web itself.
# Used in OpenGraph metadata, canonical URLs, and share links.
NEXT_PUBLIC_CAREER_WEB_URL=https://cv.irnocollege.com
