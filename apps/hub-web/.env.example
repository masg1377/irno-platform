# ─────────────────────────────────────────────────────────────────────
# irno-platform — Hub web environment example
# Copy to apps/hub-web/.env.local and fill in values for local dev.
#
# Local ports:
#   Hub Web:     http://localhost:3000  ← this app
#   Hub API:     http://localhost:4000
#   Meetino Web: http://localhost:3001
# ─────────────────────────────────────────────────────────────────────

# ── Hub API URL ───────────────────────────────────────────────
# Used by Next.js server components for server-to-server calls.
# NOT exposed to the browser — no NEXT_PUBLIC_ prefix.
HUB_API_URL=http://localhost:4000

# Used by /sso/meetino route handler for SSO code generation (server-to-server).
# In production this may be an internal network URL different from the public URL.
HUB_API_INTERNAL_URL=http://localhost:4000
