# ─────────────────────────────────────────────────────────────────────────────
# irno-platform — Hub Web — PRODUCTION environment template
#
# Copy to apps/hub-web/.env.local and fill in every value before deploying.
#
# ⚠️  NEVER commit the real .env.local file to git.
#
# Build-time vs runtime:
#   Variables prefixed NEXT_PUBLIC_* are baked into the JavaScript bundle at
#   "next build" time. Changing them requires rebuilding the Docker image.
#   Variables without that prefix are read at runtime by Next.js server
#   components and route handlers — no rebuild required when they change.
# ─────────────────────────────────────────────────────────────────────────────


# ── Hub API URL (server-side, runtime) ───────────────────────────────────────
# Used by Next.js server components and route handlers for server-to-server
# calls to hub-api. NOT exposed to the browser.
# In Docker, use the internal compose service name instead of a public URL.
HUB_API_URL=http://hub-api:4000

# Used by the /sso/meetino route handler for SSO code generation.
# In a single-VPS setup this is identical to HUB_API_URL.
HUB_API_INTERNAL_URL=http://hub-api:4000


# ── Career Web URL (server-side, runtime) ────────────────────────────────────
# Used by hub-web server components to build links to career-web.
# Not exposed to the browser directly via this variable — use the
# NEXT_PUBLIC_CAREER_WEB_URL variant below for client-side links.
CAREER_WEB_URL=https://cv.irnocollege.com


# ── Public URLs (baked at build time — rebuild image if these change) ─────────
# These values are embedded in the client-side JS bundle during "next build".
# ⚠️  If you change any NEXT_PUBLIC_* value, you MUST rebuild the Docker image.

# URL of career-web used in links rendered by the browser.
NEXT_PUBLIC_CAREER_WEB_URL=https://cv.irnocollege.com

# Meetino SSO callback URL — where Meetino redirects after Hub SSO handoff.
# Must match the value in MEETINO_ALLOWED_REDIRECT_URLS in hub-api .env.
NEXT_PUBLIC_MEETINO_CALLBACK_URL=https://meet.irnocollege.com/auth/irno/callback
