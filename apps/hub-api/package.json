{
  "name": "@irno/hub-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/apps/hub-api/src/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma generate && ts-node --project tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@irno/types": "workspace:*",
    "@irno/validators": "workspace:*",
    "@nestjs/common": "11.1.24",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.24",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/terminus": "11.1.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "dotenv": "17.4.2",
    "helmet": "8.2.0",
    "ioredis": "5.11.0",
    "pdf-parse": "^2.4.5",
    "pg": "8.21.0",
    "playwright": "^1.60.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@irno/config": "workspace:*",
    "@nestjs/cli": "11.0.21",
    "@nestjs/schematics": "11.1.0",
    "@types/bcryptjs": "3.0.0",
    "@types/cookie-parser": "1.4.9",
    "@types/express": "5.0.3",
    "@types/node": "22.15.30",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "8.20.0",
    "prisma": "7.8.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
