# ─────────────────────────────────────────────────────────────────────────────
# irno-platform — Hub API — PRODUCTION environment template
#
# Copy to apps/hub-api/.env and fill in every value before deploying.
#
# ⚠️  NEVER commit the real .env file to git.
# ⚠️  Generate every secret value with: openssl rand -hex 32
#
# Production URLs:
#   Hub Web:      https://platform.irnocollege.com
#   Hub API:      https://platform.irnocollege.com/api  (proxied via host Nginx)
#   Career Web:   https://cv.irnocollege.com
#   Meetino:      https://meet.irnocollege.com
#   LiveKit:      wss://livekit.irnocollege.com
#   PostgreSQL:   postgres:5432   (Docker internal, no host port exposed)
#   Redis:        redis:6379      (Docker internal, no host port exposed)
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ──────────────────────────────────────────────────────────────
# NODE_ENV must be "production" in all deployed containers.
NODE_ENV=production
API_PORT=4000

# Comma-separated list of allowed frontend origins for CORS.
# ⚠️  The correct key is API_CORS_ORIGINS (plural). API_CORS_ORIGIN (singular)
#    is a known typo in older env examples and will silently break all CORS.
# All three browser origins must be listed (platform + cv + meet).
API_CORS_ORIGINS=https://platform.irnocollege.com,https://cv.irnocollege.com,https://meet.irnocollege.com

# URL of the career-web frontend (used by hub-api for redirect references).
CAREER_WEB_URL=https://cv.irnocollege.com


# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. In Docker, hostname is the compose service name.
# Database must exist before running prisma migrate deploy.
# ⚠️  Use a strong random password. Generate with: openssl rand -hex 32
DATABASE_URL=postgresql://irno:YOUR_DB_PASSWORD@postgres:5432/irno_hub?schema=public


# ── Redis ────────────────────────────────────────────────────────────────────
# Redis is used for: refresh tokens, rate-limit counters, OTP cooldowns,
# SSO one-time codes, and application-level caching.
# In Docker, REDIS_HOST is the compose service name.
# ⚠️  Set a strong password. Redis is on the internal Docker network but
#    defence-in-depth requires authentication.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD


# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Two independent secrets — access and refresh tokens must use different keys.
# Generate each independently: openssl rand -hex 32
# ⚠️  Never reuse dev secrets in production.
JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d


# ── First Admin (Seed) ───────────────────────────────────────────────────────
# ⚠️  MUST SET all three SUPER_ADMIN_* variables before running db:seed
#    in production. The seed creates the initial SUPER_ADMIN account.
# ⚠️  NEVER use the development default password (IrnoAdmin@2026) in production.
# ⚠️  After the first deployment and successful login, you may remove these
#    variables from the running container (the account already exists in the DB).
SUPER_ADMIN_MOBILE=09xxxxxxxxx
SUPER_ADMIN_EMAIL=admin@irnocollege.com
SUPER_ADMIN_PASSWORD=GENERATE_WITH__openssl_rand_hex_32


# ── PDF Export (Playwright / Chromium) ───────────────────────────────────────
# hub-api is the only app that generates PDFs. Playwright is handled entirely
# inside the Dockerfile via Alpine system Chromium packages — no extra install
# step is needed in Docker.
#
# EXPORT_STORAGE_PATH must point to a directory backed by a persistent
# Docker volume. PDF files written here survive container restarts.
# Docker volume: hub_pdf_exports → /app/storage/exports
PDF_EXPORT_ENABLED=true
PDF_EXPORT_CONCURRENCY=1
PDF_EXPORT_QUEUE_MAX=5
PDF_EXPORT_TIMEOUT_MS=30000
EXPORT_STORAGE_PATH=/app/storage/exports


# ── OTP Authentication ───────────────────────────────────────────────────────
# Controls the lifecycle of OTP codes used for mobile-first login.
# Cooldown is enforced via a Redis key (not a DB query).
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60


# ── Notification / SMS Provider ──────────────────────────────────────────────
# Controls which channel providers are active.
# Default is mock (logs to console). For production SMS, replace 'mock' with
# the provider name and add the provider's env vars (e.g. KAVENEGAR_API_KEY).
# No module sends SMS/email directly — all delivery routes through NotificationsModule.
NOTIFICATION_SMS_PROVIDER=mock
NOTIFICATION_PUSH_PROVIDER=none
NOTIFICATION_EMAIL_PROVIDER=none
NOTIFICATION_TELEGRAM_PROVIDER=none


# ── Meetino Integration (Phase 9) ────────────────────────────────────────────
# Set MEETINO_ENABLED=true to activate server-to-server API integration.
# Hub still allows manual Meetino link entry when this is false.
MEETINO_ENABLED=true
MEETINO_WEB_URL=https://meet.irnocollege.com
# Server-to-server — use internal Docker service name
MEETINO_API_URL=http://meetino-api:4001
MEETINO_OPEN_IN_NEW_TAB=true

# Shared secret for server-to-server SSO code exchange between Hub and Meetino.
# ⚠️  This value must ALSO be set as IRNO_HUB_CLIENT_SECRET in meetino-api .env.
# ⚠️  Never expose this value to the browser.
# Generate with: openssl rand -hex 32
MEETINO_CLIENT_SECRET=GENERATE_WITH__openssl_rand_hex_32

# Lifetime of the one-time SSO code in seconds (10–300).
MEETINO_SSO_CODE_TTL_SECONDS=60

# Allowlist of Meetino callback URLs for SSO redirect validation (comma-separated).
# Must match exactly (scheme + host + path, no trailing slash).
MEETINO_ALLOWED_REDIRECT_URLS=https://meet.irnocollege.com/auth/irno/callback
