// ── Models ──────────────────────────────────────────────────

/// Central identity for every human in the system.
/// Staff, students, applicants, and guests all have a User record.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String?    @unique @db.VarChar(255)
  mobile       String     @unique @db.VarChar(20)
  passwordHash String?    @db.VarChar(255)
  role         UserRole   @default(STUDENT)
  status       UserStatus @default(PENDING)
  activatedAt  DateTime?  @db.Timestamptz
  createdAt    DateTime   @default(now()) @db.Timestamptz
  updatedAt    DateTime   @updatedAt @db.Timestamptz
  deletedAt    DateTime?  @db.Timestamptz

  profile                 Profile?
  studentProfile          Student?               @relation("StudentUser")
  createdApplicants       Applicant[]            @relation("ApplicantCreator")
  assignedApplicants      Applicant[]            @relation("ApplicantAssignee")
  applicantNotes          ApplicantNote[]        @relation("ApplicantNoteAuthor")
  timelineEventsActed     StudentTimelineEvent[] @relation("TimelineActor")
  staffAssignments        StaffAssignment[]      @relation("AssignmentStaff")
  assignmentsCreated      StaffAssignment[]      @relation("AssignmentAssigner")
  createdCourses          Course[]               @relation("CourseCreator")
  teachingGroups          CourseGroup[]          @relation("CourseGroupTeacher")
  createdGroups           CourseGroup[]          @relation("CourseGroupCreator")
  mentorGroups            CourseGroupMentor[]
  createdEnrollments      Enrollment[]           @relation("EnrollmentCreator")
  recordedTransactions    PaymentTransaction[]   @relation("TransactionRecorder")
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  createdEvents           Event[]               @relation("EventCreator")
  eventRegistrations      EventRegistration[]   @relation("EventRegistrationUser")
  recordedEventPayments   EventPaymentTransaction[] @relation("EventPaymentRecorder")
  meetinoReferences       MeetinoMeetingReference[] @relation("MeetinoReferenceCreator")
  // Phase 12: Skills & Credits
  awardedSkills           StudentSkill[]            @relation("SkillAwardedBy")
  awardedCredits          StudentCredit[]           @relation("CreditAwardedBy")
  revokedCredits          StudentCredit[]           @relation("CreditRevokedBy")
  // Phase 13: Certificates
  issuedCertificates      StudentCertificate[]      @relation("CertificateIssuedBy")
  revokedCertificates     StudentCertificate[]      @relation("CertificateRevokedBy")
  // Phase 14: Career Studio
  careerProfile           CareerProfile?
  resumeDocuments         ResumeDocument[]
  resumeExports           ResumeExport[]
  resumeCheckReports      ResumeCheckReport[]
  portfolioProjects       PortfolioProject[]
  jobMatchReports         JobMatchReport[]

  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@index([mobile])
  @@map("users")
}

/// Extended personal and contact information.
model Profile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  firstName       String   @db.VarChar(100)
  lastName        String   @db.VarChar(100)
  avatarUrl       String?  @db.VarChar(500)
  city            String?  @db.VarChar(100)
  bio             String?  @db.Text
  telegramHandle  String?  @db.VarChar(100)
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// Registry of Irno apps available in the app launcher.
model AppModule {
  id           String          @id @default(uuid()) @db.Uuid
  key          String          @unique @db.VarChar(50)
  nameLocal    String          @db.VarChar(100)
  description  String?         @db.Text
  url          String          @db.VarChar(500)
  iconUrl      String?         @db.VarChar(500)
  status       AppModuleStatus @default(COMING_SOON)
  allowedRoles String[]
  sortOrder    Int             @default(0)
  createdAt    DateTime        @default(now()) @db.Timestamptz
  updatedAt    DateTime        @updatedAt @db.Timestamptz

  @@index([status])
  @@map("app_modules")
}

// ── Phase 3: CRM ─────────────────────────────────────────────

/// A person interested in registering for a course at Irno.
model Applicant {
  id                    String           @id @default(uuid()) @db.Uuid
  fullName              String           @db.VarChar(200)
  mobile                String           @db.VarChar(20)
  email                 String?          @db.VarChar(255)
  city                  String?          @db.VarChar(100)
  source                ApplicantSource  @default(OTHER)
  interestedTopic       String?          @db.VarChar(300)
  interestedCourseId       String?          @db.Uuid
  interestedCourseGroupId  String?          @db.Uuid
  status                   ApplicantStatus  @default(NEW_APPLICANT)
  consultationNotes     String?          @db.Text
  followUpDate          DateTime?        @db.Timestamptz
  assignedToUserId      String?          @db.Uuid
  convertedToStudentId  String?          @unique @db.Uuid
  convertedAt           DateTime?        @db.Timestamptz
  createdById           String           @db.Uuid
  createdAt             DateTime         @default(now()) @db.Timestamptz
  updatedAt             DateTime         @updatedAt @db.Timestamptz
  deletedAt             DateTime?        @db.Timestamptz

  assignedTo            User?            @relation("ApplicantAssignee", fields: [assignedToUserId], references: [id])
  createdBy             User             @relation("ApplicantCreator", fields: [createdById], references: [id])
  convertedToStudent    Student?         @relation("ApplicantConversion", fields: [convertedToStudentId], references: [id])
  interestedCourse      Course?      @relation("ApplicantInterestedCourse", fields: [interestedCourseId], references: [id])
  interestedCourseGroup CourseGroup? @relation("ApplicantInterestedCourseGroup", fields: [interestedCourseGroupId], references: [id])
  notes                 ApplicantNote[]
  eventRegistrations    EventRegistration[] @relation("EventRegistrationApplicant")

  @@index([mobile])
  @@index([status])
  @@index([source])
  @@index([followUpDate])
  @@index([assignedToUserId])
  @@index([convertedAt])
  @@index([deletedAt])
  @@index([interestedCourseId])
  @@index([interestedCourseGroupId])
  @@map("applicants")
}

/// A note attached to an applicant by a staff member.
model ApplicantNote {
  id           String    @id @default(uuid()) @db.Uuid
  applicantId  String    @db.Uuid
  authorId     String    @db.Uuid
  content      String    @db.Text
  createdAt    DateTime  @default(now()) @db.Timestamptz

  applicant    Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  author       User      @relation("ApplicantNoteAuthor", fields: [authorId], references: [id])

  @@index([applicantId])
  @@map("applicant_notes")
}

/// A registered student in Irno Academy.
model Student {
  id                 String        @id @default(uuid()) @db.Uuid
  userId             String        @unique @db.Uuid
  studentCode        String        @unique @db.VarChar(30)
  originApplicantId  String?       @db.Uuid
  status             StudentStatus @default(ACTIVE)
  internalNotes      String?       @db.Text
  createdAt          DateTime      @default(now()) @db.Timestamptz
  updatedAt          DateTime      @updatedAt @db.Timestamptz
  deletedAt          DateTime?     @db.Timestamptz

  user              User                   @relation("StudentUser", fields: [userId], references: [id])
  originApplicant   Applicant?             @relation("ApplicantConversion")
  timelineEvents    StudentTimelineEvent[]
  enrollments       Enrollment[]
  eventRegistrations EventRegistration[]   @relation("EventRegistrationStudent")
  // Phase 12: Skills & Credits
  studentSkills      StudentSkill[]
  studentCredits     StudentCredit[]
  // Phase 13: Certificates
  certificates       StudentCertificate[]

  @@index([userId])
  @@index([studentCode])
  @@index([status])
  @@index([originApplicantId])
  @@index([deletedAt])
  @@map("students")
}

/// Immutable audit log of everything that has happened to a student.
model StudentTimelineEvent {
  id         String            @id @default(uuid()) @db.Uuid
  studentId  String            @db.Uuid
  eventType  TimelineEventType
  actorId    String?           @db.Uuid
  title      String            @db.VarChar(500)
  metadata   Json?
  isManual   Boolean           @default(false)
  createdAt  DateTime          @default(now()) @db.Timestamptz

  student    Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actor      User?             @relation("TimelineActor", fields: [actorId], references: [id])

  @@index([studentId, createdAt(sort: Desc)])
  @@map("student_timeline_events")
}

/// Tracks which staff member is assigned to an applicant or student.
model StaffAssignment {
  id           String               @id @default(uuid()) @db.Uuid
  staffId      String               @db.Uuid
  targetType   AssignmentTargetType
  targetId     String               @db.Uuid
  assignedAt   DateTime             @default(now()) @db.Timestamptz
  assignedById String               @db.Uuid
  isActive     Boolean              @default(true)

  staff        User                 @relation("AssignmentStaff", fields: [staffId], references: [id])
  assignedBy   User                 @relation("AssignmentAssigner", fields: [assignedById], references: [id])

  @@index([targetType, targetId])
  @@index([staffId])
  @@index([isActive])
  @@map("staff_assignments")
}

// ── Phase 4: Academic Structure ───────────────────────────────

/// An educational product offered by Irno Academy.
/// Examples: React course, Next.js course, AI course, Language course.
model Course {
  id                   String       @id @default(uuid()) @db.Uuid
  title                String       @db.VarChar(200)
  slug                 String       @unique @db.VarChar(100)
  description          String?      @db.Text
  category             String       @db.VarChar(100)
  /** Phase 12.1: structured category from taxonomy. Falls back to legacy category string. */
  categoryId           String?      @db.Uuid
  legacyCategory       String?      @db.VarChar(100)
  level                CourseLevel  @default(ALL_LEVELS)
  defaultTuitionToman  Int?
  status               CourseStatus @default(DRAFT)
  createdById          String       @db.Uuid
  createdAt            DateTime     @default(now()) @db.Timestamptz
  updatedAt            DateTime     @updatedAt @db.Timestamptz
  deletedAt            DateTime?    @db.Timestamptz

  createdBy            User         @relation("CourseCreator", fields: [createdById], references: [id])
  taxonomyCategory     TaxonomyTerm? @relation("CourseTaxonomyCategory", fields: [categoryId], references: [id])
  courseGroups         CourseGroup[]
  interestedApplicants Applicant[]  @relation("ApplicantInterestedCourse")
  enrollments          Enrollment[]

  @@index([status])
  @@index([category])
  @@index([categoryId])
  @@index([level])
  @@index([deletedAt])
  @@map("courses")
}

/// A specific running class/group for a Course.
/// Examples: React Group A, Next.js Summer Group, React Native Private Group.
model CourseGroup {
  id             String            @id @default(uuid()) @db.Uuid
  courseId       String            @db.Uuid
  name           String            @db.VarChar(200)
  teacherId      String?           @db.Uuid
  startDate      DateTime?         @db.Timestamptz
  endDate        DateTime?         @db.Timestamptz
  scheduleNotes  String?           @db.Text
  capacity       Int?
  status         CourseGroupStatus @default(UPCOMING)
  meetinoRoomId  String?           @db.VarChar(100)
  createdById    String            @db.Uuid
  createdAt      DateTime          @default(now()) @db.Timestamptz
  updatedAt      DateTime          @updatedAt @db.Timestamptz
  deletedAt      DateTime?         @db.Timestamptz

  course                Course            @relation(fields: [courseId], references: [id])
  teacher               User?             @relation("CourseGroupTeacher", fields: [teacherId], references: [id])
  createdBy             User              @relation("CourseGroupCreator", fields: [createdById], references: [id])
  mentors               CourseGroupMentor[]
  enrollments           Enrollment[]
  interestedApplicants  Applicant[]       @relation("ApplicantInterestedCourseGroup")

  @@index([courseId])
  @@index([teacherId])
  @@index([status])
  @@index([startDate])
  @@index([deletedAt])
  @@map("course_groups")
}

/// Join table: mentor assignment to a course group.
model CourseGroupMentor {
  courseGroupId  String      @db.Uuid
  userId         String      @db.Uuid
  assignedAt     DateTime    @default(now()) @db.Timestamptz

  courseGroup    CourseGroup @relation(fields: [courseGroupId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id])

  @@id([courseGroupId, userId])
  @@index([userId])
  @@map("course_group_mentors")
}

// ── Phase 5: Finance ──────────────────────────────────────────

/// Official registration of a student in a course/group.
/// Created transactionally together with a Payment record.
model Enrollment {
  id                   String           @id @default(uuid()) @db.Uuid
  studentId            String           @db.Uuid
  courseId             String           @db.Uuid
  courseGroupId        String?          @db.Uuid
  status               EnrollmentStatus @default(PENDING)
  tuitionAmountToman   Int
  discountAmountToman  Int              @default(0)
  finalAmountToman     Int
  enrollmentDate       DateTime         @db.Timestamptz
  notes                String?          @db.Text
  createdById          String           @db.Uuid
  createdAt            DateTime         @default(now()) @db.Timestamptz
  updatedAt            DateTime         @updatedAt @db.Timestamptz
  deletedAt            DateTime?        @db.Timestamptz

  student              Student          @relation(fields: [studentId], references: [id])
  course               Course           @relation(fields: [courseId], references: [id])
  courseGroup          CourseGroup?     @relation(fields: [courseGroupId], references: [id])
  createdBy            User             @relation("EnrollmentCreator", fields: [createdById], references: [id])
  payment              Payment?

  @@index([studentId])
  @@index([courseId])
  @@index([courseGroupId])
  @@index([status])
  @@index([enrollmentDate])
  @@index([deletedAt])
  @@map("enrollments")
}

/// Financial record for one enrollment. Created automatically with Enrollment.
/// Tracks total, paid, and remaining amounts.
model Payment {
  id                   String        @id @default(uuid()) @db.Uuid
  enrollmentId         String        @unique @db.Uuid
  studentId            String        @db.Uuid
  totalAmountToman     Int
  paidAmountToman      Int           @default(0)
  remainingAmountToman Int
  status               PaymentStatus @default(UNPAID)
  notes                String?       @db.Text
  createdAt            DateTime      @default(now()) @db.Timestamptz
  updatedAt            DateTime      @updatedAt @db.Timestamptz

  enrollment           Enrollment         @relation(fields: [enrollmentId], references: [id])
  transactions         PaymentTransaction[]
  installments         Installment[]

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

/// One manually recorded payment for an enrollment.
/// Immutable in MVP — no edits or deletes allowed.
model PaymentTransaction {
  id            String        @id @default(uuid()) @db.Uuid
  paymentId     String        @db.Uuid
  amountToman   Int
  method        PaymentMethod @default(CASH)
  paidAt        DateTime      @db.Timestamptz
  receiptNote   String?       @db.VarChar(500)
  recordedById  String        @db.Uuid
  createdAt     DateTime      @default(now()) @db.Timestamptz

  payment       Payment       @relation(fields: [paymentId], references: [id])
  recordedBy    User          @relation("TransactionRecorder", fields: [recordedById], references: [id])

  @@index([paymentId])
  @@index([paidAt])
  @@index([recordedById])
  @@map("payment_transactions")
}

// ── Phase 7: Notifications ────────────────────────────────────

/// In-app or external notification sent to a user.
model Notification {
  id                 String               @id @default(uuid()) @db.Uuid
  recipientUserId    String               @db.Uuid
  title              String
  body               String
  type               NotificationType
  channel            NotificationChannel  @default(IN_APP)
  status             NotificationStatus   @default(PENDING)
  priority           NotificationPriority @default(NORMAL)
  relatedEntityType  String?
  relatedEntityId    String?
  metadata           Json?
  readAt             DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  recipient          User                 @relation(fields: [recipientUserId], references: [id])
  deliveries         NotificationDelivery[]

  @@index([recipientUserId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([readAt])
  @@index([createdAt])
  @@index([relatedEntityType, relatedEntityId])
  @@map("notifications")
}

/// Reusable template for generating notifications by key.
model NotificationTemplate {
  id        String              @id @default(uuid()) @db.Uuid
  key       String              @unique
  title     String
  body      String
  type      NotificationType
  channel   NotificationChannel
  isActive  Boolean             @default(true)
  variables Json?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deletedAt DateTime?

  @@index([key])
  @@index([type])
  @@index([channel])
  @@index([isActive])
  @@index([deletedAt])
  @@map("notification_templates")
}

/// Delivery attempt record for a notification on a specific channel.
model NotificationDelivery {
  id                String              @id @default(uuid()) @db.Uuid
  notificationId    String               @db.Uuid
  channel           NotificationChannel
  status            NotificationStatus
  provider          String?
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  notification      Notification        @relation(fields: [notificationId], references: [id])

  @@index([notificationId])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
  @@map("notification_deliveries")
}

/// Per-user notification delivery preferences.
model NotificationPreference {
  id                        String   @id @default(uuid()) @db.Uuid
  userId                    String   @unique @db.Uuid
  inAppEnabled              Boolean  @default(true)
  smsTransactionalEnabled   Boolean  @default(true)
  smsMarketingEnabled       Boolean  @default(false)
  emailEnabled              Boolean  @default(false)
  telegramEnabled           Boolean  @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user                      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notification_preferences")
}

// ── Phase 8: Events ───────────────────────────────────────────

/// An educational or community event managed by Irno.
/// Examples: webinars, conferences, workshops, free discussions, open sessions.
model Event {
  id                   String                @id @default(uuid()) @db.Uuid
  title                String                @db.VarChar(300)
  slug                 String                @unique @db.VarChar(150)
  description          String?               @db.Text
  type                 EventType
  deliveryMode         EventDeliveryMode
  registrationMode     EventRegistrationMode
  status               EventStatus           @default(DRAFT)
  startsAt             DateTime              @db.Timestamptz
  endsAt               DateTime?             @db.Timestamptz
  location             String?               @db.VarChar(500)
  onlineUrl            String?               @db.VarChar(500)
  meetinoMeetingId     String?               @db.VarChar(100)
  meetinoJoinUrl       String?               @db.VarChar(500)
  capacity             Int?
  priceToman           Int                   @default(0)
  registrationDeadline DateTime?             @db.Timestamptz
  categoryId           String?               @db.Uuid
  createdById          String                @db.Uuid
  createdAt            DateTime              @default(now()) @db.Timestamptz
  updatedAt            DateTime              @updatedAt @db.Timestamptz
  deletedAt            DateTime?             @db.Timestamptz

  createdBy            User                  @relation("EventCreator", fields: [createdById], references: [id])
  taxonomyCategory     TaxonomyTerm?         @relation("EventTaxonomyCategory", fields: [categoryId], references: [id])
  registrations        EventRegistration[]
  eligibilityRules     EventEligibilityRule[]
  reminders            EventReminder[]

  @@index([type])
  @@index([deliveryMode])
  @@index([registrationMode])
  @@index([status])
  @@index([categoryId])
  @@index([startsAt])
  @@index([deletedAt])
  @@map("events")
}

/// A person registered for an event (student, applicant, or external).
model EventRegistration {
  id                   String                          @id @default(uuid()) @db.Uuid
  eventId              String                          @db.Uuid
  userId               String?                         @db.Uuid
  studentId            String?                         @db.Uuid
  applicantId          String?                         @db.Uuid
  fullName             String                          @db.VarChar(200)
  mobile               String                          @db.VarChar(20)
  email                String?                         @db.VarChar(255)
  status               EventRegistrationStatus         @default(PENDING)
  paymentStatus        EventRegistrationPaymentStatus  @default(NOT_REQUIRED)
  amountDueToman       Int                             @default(0)
  paidAmountToman      Int                             @default(0)
  remainingAmountToman Int                             @default(0)
  registeredAt         DateTime                        @default(now()) @db.Timestamptz
  checkedInAt          DateTime?                       @db.Timestamptz
  cancelledAt          DateTime?                       @db.Timestamptz
  notes                String?                         @db.Text
  createdById          String?                         @db.Uuid
  createdAt            DateTime                        @default(now()) @db.Timestamptz
  updatedAt            DateTime                        @updatedAt @db.Timestamptz
  deletedAt            DateTime?                       @db.Timestamptz

  event                Event                           @relation(fields: [eventId], references: [id])
  user                 User?                           @relation("EventRegistrationUser", fields: [userId], references: [id])
  student              Student?                        @relation("EventRegistrationStudent", fields: [studentId], references: [id])
  applicant            Applicant?                      @relation("EventRegistrationApplicant", fields: [applicantId], references: [id])
  paymentTransactions  EventPaymentTransaction[]

  @@index([eventId])
  @@index([userId])
  @@index([studentId])
  @@index([applicantId])
  @@index([mobile])
  @@index([status])
  @@index([paymentStatus])
  @@index([registeredAt])
  @@index([deletedAt])
  @@map("event_registrations")
}

/// Manual payment recorded for a paid event registration.
model EventPaymentTransaction {
  id                   String            @id @default(uuid()) @db.Uuid
  eventRegistrationId  String            @db.Uuid
  amountToman          Int
  method               PaymentMethod     @default(CASH)
  paidAt               DateTime          @db.Timestamptz
  receiptNote          String?           @db.VarChar(500)
  recordedById         String            @db.Uuid
  createdAt            DateTime          @default(now()) @db.Timestamptz

  registration         EventRegistration @relation(fields: [eventRegistrationId], references: [id])
  recordedBy           User              @relation("EventPaymentRecorder", fields: [recordedById], references: [id])

  @@index([eventRegistrationId])
  @@index([paidAt])
  @@index([recordedById])
  @@map("event_payment_transactions")
}

/// Eligibility rule restricting who can register for an event.
model EventEligibilityRule {
  id        String                   @id @default(uuid()) @db.Uuid
  eventId   String                   @db.Uuid
  type      EventEligibilityRuleType
  operator  String?                  @db.VarChar(50)
  value     Json?
  isRequired Boolean                 @default(true)
  createdAt DateTime                 @default(now()) @db.Timestamptz
  updatedAt DateTime                 @updatedAt @db.Timestamptz

  event     Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([type])
  @@map("event_eligibility_rules")
}

/// Scheduled reminder notification for an event.
model EventReminder {
  id                     String              @id @default(uuid()) @db.Uuid
  eventId                String              @db.Uuid
  type                   EventReminderType
  scheduledAt            DateTime            @db.Timestamptz
  channel                NotificationChannel
  status                 EventReminderStatus @default(PENDING)
  notificationTemplateId String?             @db.Uuid
  createdAt              DateTime            @default(now()) @db.Timestamptz
  updatedAt              DateTime            @updatedAt @db.Timestamptz

  event                  Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([scheduledAt])
  @@index([status])
  @@map("event_reminders")
}

// ── Phase 9: Meetino Integration ─────────────────────────────

/// External Meetino meeting reference stored in Hub.
/// sourceType + sourceId links to a CourseGroup or Event.
/// Hub does not store Meetino secrets — only public join URLs and slugs.
model MeetinoMeetingReference {
  id               String                    @id @default(uuid()) @db.Uuid
  sourceType       MeetinoMeetingSourceType
  sourceId         String                    @db.Uuid
  meetinoMeetingId String?                   @db.VarChar(200)
  meetinoSlug      String?                   @db.VarChar(200)
  title            String                    @db.VarChar(300)
  joinUrl          String                    @db.VarChar(500)
  hostUrl          String?                   @db.VarChar(500)
  status           MeetinoMeetingStatus      @default(UNKNOWN)
  startsAt         DateTime?                 @db.Timestamptz
  endsAt           DateTime?                 @db.Timestamptz
  createdById      String                    @db.Uuid
  lastSyncedAt     DateTime?                 @db.Timestamptz
  metadata         Json?
  createdAt        DateTime                  @default(now()) @db.Timestamptz
  updatedAt        DateTime                  @updatedAt @db.Timestamptz
  deletedAt        DateTime?                 @db.Timestamptz

  createdBy        User                      @relation("MeetinoReferenceCreator", fields: [createdById], references: [id])
  attendanceRecords MeetinoAttendanceRecord[]

  @@index([sourceType, sourceId])
  @@index([meetinoMeetingId])
  @@index([meetinoSlug])
  @@index([status])
  @@index([startsAt])
  @@index([deletedAt])
  @@map("meetino_meeting_references")
}

/// Attendance record synced (or manually imported) from a Meetino meeting report.
model MeetinoAttendanceRecord {
  id                   String                  @id @default(uuid()) @db.Uuid
  referenceId          String                  @db.Uuid
  meetinoParticipantId String?                 @db.VarChar(200)
  userId               String?                 @db.Uuid
  studentId            String?                 @db.Uuid
  displayName          String                  @db.VarChar(200)
  participantType      MeetinoParticipantType  @default(REGISTERED)
  joinedAt             DateTime?               @db.Timestamptz
  leftAt               DateTime?               @db.Timestamptz
  durationSeconds      Int?
  wasGuest             Boolean                 @default(false)
  rawData              Json?
  createdAt            DateTime                @default(now()) @db.Timestamptz
  updatedAt            DateTime                @updatedAt @db.Timestamptz

  reference            MeetinoMeetingReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@index([referenceId])
  @@index([studentId])
  @@index([userId])
  @@index([joinedAt])
  @@map("meetino_attendance_records")
}

// ── Phase 11.1: OTP ──────────────────────────────────────────

/// One-time password record for mobile-based login, registration, and account activation.
/// Raw code is NEVER stored — only bcrypt hash.
/// A record is consumed (consumedAt set) after successful verification.
/// Expired and consumed records should be pruned periodically (future cron).
model OtpCode {
  id          String     @id @default(uuid()) @db.Uuid
  mobile      String     @db.VarChar(20)
  userId      String?    @db.Uuid
  codeHash    String     @db.VarChar(255)
  purpose     OtpPurpose @default(LOGIN)
  expiresAt   DateTime   @db.Timestamptz
  consumedAt  DateTime?  @db.Timestamptz
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  createdAt   DateTime   @default(now()) @db.Timestamptz

  @@index([mobile, createdAt(sort: Desc)])
  @@index([mobile, consumedAt, expiresAt])
  @@map("otp_codes")
}

/// Scheduled installment for a payment.
/// Overdue status is computed on-read (dueDate < now and status = PENDING).
model Installment {
  id                  String            @id @default(uuid()) @db.Uuid
  paymentId           String            @db.Uuid
  studentId           String            @db.Uuid
  installmentNumber   Int
  amountToman         Int
  dueDate             DateTime          @db.Timestamptz
  paidAt              DateTime?         @db.Timestamptz
  status              InstallmentStatus @default(PENDING)
  notes               String?           @db.VarChar(500)
  createdAt           DateTime          @default(now()) @db.Timestamptz
  updatedAt           DateTime          @updatedAt @db.Timestamptz

  payment             Payment           @relation(fields: [paymentId], references: [id])

  @@unique([paymentId, installmentNumber])
  @@index([paymentId])
  @@index([studentId])
  @@index([dueDate])
  @@index([status])
  @@index([status, dueDate])
  @@map("installments")
}

