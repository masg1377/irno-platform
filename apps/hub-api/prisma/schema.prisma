  IN_PERSON
  HYBRID
}

enum EventRegistrationMode {
  FREE
  PAID
  INVITE_ONLY
  INTERNAL_ONLY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  REGISTRATION_OPEN
  REGISTRATION_CLOSED
  LIVE
  COMPLETED
  CANCELLED
}

enum EventRegistrationStatus {
