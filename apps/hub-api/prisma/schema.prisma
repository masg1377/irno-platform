  EXPIRED
  REVOKED
}

/// A skill in the Irno skill catalog (e.g. "React Components", "English B1").
model Skill {
  id             String      @id @default(uuid()) @db.Uuid
  title          String      @db.VarChar(255)
  slug           String      @unique @db.VarChar(255)
  description    String?     @db.Text
  category       String?     @db.VarChar(100)
  categoryId     String?     @db.Uuid
  legacyCategory String?     @db.VarChar(100)
  level          SkillLevel
  status         SkillStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @db.Timestamptz
  updatedAt      DateTime    @updatedAt @db.Timestamptz
  deletedAt      DateTime?   @db.Timestamptz

  taxonomyCategory TaxonomyTerm? @relation("SkillTaxonomyCategory", fields: [categoryId], references: [id])
  studentSkills    StudentSkill[]

  @@index([status])
  @@index([category])
  @@index([categoryId])
  @@index([level])
  @@index([deletedAt])
  @@map("skills")
}

/// A credit in the Irno credit catalog (e.g. "Completed React Course", "Interview Ready").
model Credit {
  id               String       @id @default(uuid()) @db.Uuid
  title            String       @db.VarChar(255)
  slug             String       @unique @db.VarChar(255)
  description      String?      @db.Text
  type             CreditType
  categoryId       String?      @db.Uuid
  legacyCategory   String?      @db.VarChar(100)
  status           CreditStatus @default(ACTIVE)
  expiresAfterDays Int?
  createdAt        DateTime     @default(now()) @db.Timestamptz
  updatedAt        DateTime     @updatedAt @db.Timestamptz
  deletedAt        DateTime?    @db.Timestamptz

  taxonomyCategory TaxonomyTerm?  @relation("CreditTaxonomyCategory", fields: [categoryId], references: [id])
  studentCredits   StudentCredit[]

  @@index([type])
  @@index([status])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("credits")
}

/// A skill awarded to a student. Unique per student+skill (upsert on re-award).
model StudentSkill {
  id           String            @id @default(uuid()) @db.Uuid
  studentId    String            @db.Uuid
  skillId      String            @db.Uuid
  level        StudentSkillLevel
  sourceType   String?           @db.VarChar(100)
  sourceId     String?           @db.Uuid
  awardedById  String            @db.Uuid
  awardedAt    DateTime          @default(now()) @db.Timestamptz
  evidenceNote String?           @db.Text
  createdAt    DateTime          @default(now()) @db.Timestamptz
  updatedAt    DateTime          @updatedAt @db.Timestamptz

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id])
  awardedBy User    @relation("SkillAwardedBy", fields: [awardedById], references: [id])

  @@unique([studentId, skillId])
  @@index([studentId])
  @@index([skillId])
  @@index([level])
  @@index([awardedAt])
  @@map("student_skills")
}

/// A credit awarded to a student. Can expire or be revoked.
model StudentCredit {
  id           String              @id @default(uuid()) @db.Uuid
  studentId    String              @db.Uuid
  creditId     String              @db.Uuid
  status       StudentCreditStatus @default(ACTIVE)
  sourceType   String?             @db.VarChar(100)
  sourceId     String?             @db.Uuid
  awardedById  String              @db.Uuid
  awardedAt    DateTime            @default(now()) @db.Timestamptz
  expiresAt    DateTime?           @db.Timestamptz
  revokedAt    DateTime?           @db.Timestamptz
  revokedById  String?             @db.Uuid
  evidenceNote String?             @db.Text
  createdAt    DateTime            @default(now()) @db.Timestamptz
  updatedAt    DateTime            @updatedAt @db.Timestamptz

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  credit    Credit   @relation(fields: [creditId], references: [id])
  awardedBy User     @relation("CreditAwardedBy", fields: [awardedById], references: [id])
  revokedBy User?    @relation("CreditRevokedBy", fields: [revokedById], references: [id])

  @@index([studentId])
  @@index([creditId])
  @@index([status])
  @@index([expiresAt])
  @@index([awardedAt])
  @@map("student_credits")
}

// ── Phase 12.1: Taxonomy / Master Data ───────────────────────

enum TaxonomyTermType {
  COURSE_CATEGORY
  SKILL_CATEGORY
  CREDIT_CATEGORY
  EVENT_CATEGORY
  RESUME_CATEGORY
  GENERAL
}

enum TaxonomyTermStatus {
  ACTIVE
  ARCHIVED
}

/// Controlled vocabulary for categories and classifications across Irno modules.
/// Replaces free-text category fields with structured, reportable taxonomy.
/// title is Persian display name. slug is English/URL-safe.
model TaxonomyTerm {
  id          String             @id @default(uuid()) @db.Uuid
  type        TaxonomyTermType
  title       String             @db.VarChar(255)
  slug        String             @db.VarChar(255)
  description String?            @db.Text
  parentId    String?            @db.Uuid
  status      TaxonomyTermStatus @default(ACTIVE)
  sortOrder   Int                @default(0)
  color       String?            @db.VarChar(50)
  icon        String?            @db.VarChar(100)
  metadata    Json?
  createdAt   DateTime           @default(now()) @db.Timestamptz
  updatedAt   DateTime           @updatedAt @db.Timestamptz
  deletedAt   DateTime?          @db.Timestamptz

  parent      TaxonomyTerm?  @relation("TaxonomyParent", fields: [parentId], references: [id])
  children    TaxonomyTerm[] @relation("TaxonomyParent")

  // Back-relations from models using this term as category
  courses     Course[]  @relation("CourseTaxonomyCategory")
  skills      Skill[]   @relation("SkillTaxonomyCategory")
  credits     Credit[]  @relation("CreditTaxonomyCategory")
  events      Event[]   @relation("EventTaxonomyCategory")

  @@unique([type, slug])
  @@index([type])
  @@index([status])
  @@index([parentId])
  @@index([deletedAt])
  @@index([type, sortOrder])
  @@map("taxonomy_terms")
}

