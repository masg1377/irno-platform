// ──────────────────────────────────────────────────────────────
// Irno Platform — Prisma Schema
// Phase 1: Foundation — User, Profile, AppModule
// Phase 3: CRM — Applicant, ApplicantNote, Student, StudentTimelineEvent, StaffAssignment
// Phase 4: Academic — Course, CourseGroup, CourseGroupMentor
// Phase 5: Finance — Enrollment, Payment, PaymentTransaction, Installment
// Phase 7: Notifications — Notification, NotificationTemplate, NotificationDelivery, NotificationPreference
// Phase 8: Events — Event, EventRegistration, EventPaymentTransaction, EventEligibilityRule, EventReminder
// Phase 9: Meetino Integration — MeetinoMeetingReference, MeetinoAttendanceRecord
//
// Rules:
//   • All field names: English (camelCase)
//   • Timestamps stored as UTC (Prisma default with @db.Timestamptz)
//   • Money: INTEGER Toman — NOT float
//   • Soft delete: deletedAt on all business records
//   • Indexes on all common query fields
// ──────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ───────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  MENTOR
  STUDENT
  GUEST
  LEAD
  APPLICANT
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum AppModuleStatus {
  ACTIVE
  COMING_SOON
  DISABLED
}

// ── Phase 3 Enums ───────────────────────────────────────────

enum ApplicantStatus {
  NEW_APPLICANT
  CONTACTED
  CONSULTED
  READY_TO_REGISTER
  REGISTERED
  NEEDS_FOLLOW_UP
  NOT_INTERESTED
  CANCELLED
}

enum ApplicantSource {
  INSTAGRAM
  REFERRAL
  WEBSITE
  PHONE
  TELEGRAM
  WHATSAPP
  IN_PERSON
  OTHER
}

enum StudentStatus {
  ACTIVE
  PAUSED
  GRADUATED
  CANCELLED
}

