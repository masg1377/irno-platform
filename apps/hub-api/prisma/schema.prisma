  ARCHIVED
}

enum CreditType {
  COURSE_COMPLETION
  TEST_PASSED
  MENTOR_APPROVAL
  EVENT_ATTENDANCE
  INTERVIEW_READY
  ACCESS_PERMISSION
  MANUAL
  OTHER
}

enum CreditStatus {
  ACTIVE
  ARCHIVED
}

enum StudentSkillLevel {
