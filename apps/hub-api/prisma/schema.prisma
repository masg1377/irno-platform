/// A resume document — one user can have many resumes (versions, languages, targets).
model ResumeDocument {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @db.Uuid
  careerProfileId String           @db.Uuid
  title           String           @db.VarChar(500)
  targetRole      String?          @db.VarChar(500)
  language        ResumeLanguage   @default(FA)
  templateId      String?          @db.Uuid
  visibility      ResumeVisibility @default(PRIVATE)
  publicSlug      String?          @unique @db.VarChar(255)
  styleConfig      Json?
  settings         Json?
  includeWatermark  Boolean          @default(true)
  watermarkConfig   Json?
  lastExportedAt    DateTime?        @db.Timestamptz
  allowPdfDownload  Boolean          @default(true)
  publicThemeConfig Json?
  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt       DateTime         @updatedAt @db.Timestamptz
  deletedAt       DateTime?        @db.Timestamptz

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerProfile   CareerProfile         @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)
  template        ResumeTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections        ResumeSection[]
  exports         ResumeExport[]
  checkReports    ResumeCheckReport[]
  jobMatchReports JobMatchReport[]

  @@index([userId])
  @@index([careerProfileId])
  @@index([templateId])
  @@index([visibility])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("resume_documents")
}

/// A section inside a resume document.
model ResumeSection {
  id               String            @id @default(uuid()) @db.Uuid
  resumeDocumentId String            @db.Uuid
  type             ResumeSectionType
  title            String            @db.VarChar(500)
  content          Json
  layoutConfig     Json?
  styleConfig      Json?
  sortOrder        Int               @default(0)
  isVisible        Boolean           @default(true)
  isImported       Boolean           @default(false)
  sourceType       String?           @db.VarChar(100)
  sourceId         String?           @db.Uuid
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz

  resumeDocument   ResumeDocument    @relation(fields: [resumeDocumentId], references: [id], onDelete: Cascade)

  @@index([resumeDocumentId])
  @@index([type])
  @@index([sortOrder])
  // Compound index: fetch + sort sections for a resume in one scan
  @@index([resumeDocumentId, sortOrder])
  @@map("resume_sections")
}

/// Resume template — defines layout, style defaults, and ATS/RTL capabilities.
model ResumeTemplate {
  id                 String             @id @default(uuid()) @db.Uuid
  title              String             @db.VarChar(255)
  slug               String             @unique @db.VarChar(255)
  type               ResumeTemplateType
  language           ResumeLanguage     @default(FA_EN)
  description        String?            @db.Text
  previewUrl         String?            @db.VarChar(500)
  layoutConfig       Json?
  defaultStyleConfig Json?
  defaultSections    Json?
  isPremium          Boolean            @default(false)
  isActive           Boolean            @default(true)
  supportsAts        Boolean            @default(false)
  supportsRtl        Boolean            @default(true)
  supportsLtr        Boolean            @default(true)
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now()) @db.Timestamptz
  updatedAt          DateTime           @updatedAt @db.Timestamptz
  deletedAt          DateTime?          @db.Timestamptz

  resumes            ResumeDocument[]
  exports            ResumeExport[]

  @@index([type])
  @@index([isActive])
  @@index([isPremium])
  @@index([supportsAts])
  @@index([deletedAt])
  @@map("resume_templates")
}

/// Export record — tracks PDF/HTML export requests with watermark config.
model ResumeExport {
  id               String             @id @default(uuid()) @db.Uuid
  resumeDocumentId String             @db.Uuid
  userId           String             @db.Uuid
  templateId       String?            @db.Uuid
  format           ResumeExportFormat @default(PDF)
  status           ResumeExportStatus @default(PENDING)
  fileUrl          String?            @db.VarChar(1000)
  htmlSnapshot     String?            @db.Text
  errorMessage     String?            @db.Text
  includeWatermark Boolean            @default(true)
  watermarkConfig  Json?
  generatedAt      DateTime?          @db.Timestamptz
  createdAt        DateTime           @default(now()) @db.Timestamptz
  updatedAt        DateTime           @updatedAt @db.Timestamptz

  resumeDocument   ResumeDocument     @relation(fields: [resumeDocumentId], references: [id], onDelete: Cascade)
  user             User               @relation(fields: [userId], references: [id])
  template         ResumeTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([resumeDocumentId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  // Compound: list exports for a resume (listExports endpoint)
  @@index([resumeDocumentId, status])
  // Compound: list all user exports ordered by date (admin / portal views)
  @@index([userId, createdAt])
  @@map("resume_exports")
}

/// Resume checker report — scores and findings for a resume.
/// Supports both Irno-built resumes and externally uploaded/pasted text.
model ResumeCheckReport {
  id                      String                @id @default(uuid()) @db.Uuid
  resumeDocumentId        String?               @db.Uuid
  userId                  String                @db.Uuid
  sourceType              ResumeCheckSourceType @default(IRNO_RESUME)
  /// Original filename if uploaded externally
  sourceFileName          String?
  /// Snapshot of text checked (for PASTED_TEXT / UPLOADED_FILE sources)
  sourceTextSnapshot      String?
  /// Optional job role the user is targeting
  targetRole              String?               @db.VarChar(255)
  /// Snapshot of the job description used for keyword matching
  jobDescriptionSnapshot  String?
  overallScore            Int                   @default(0)
  atsScore                Int                   @default(0)
  hrScanScore             Int                   @default(0)
  structureScore          Int                   @default(0)
  keywordScore            Int                   @default(0)
  achievementScore        Int                   @default(0)
  formattingRiskScore     Int                   @default(0)
  completenessScore       Int                   @default(0)
  readabilityScore        Int                   @default(0)
  /// Optional — only set when jobDescriptionSnapshot is provided
  roleMatchScore          Int?
  findings                Json
  /// Actionable suggestions (prioritised list)
  suggestions             Json?
  createdAt               DateTime              @default(now()) @db.Timestamptz

  resumeDocument      ResumeDocument?       @relation(fields: [resumeDocumentId], references: [id], onDelete: SetNull)
  user                User                  @relation(fields: [userId], references: [id])

  @@index([resumeDocumentId])
  @@index([userId])
  @@index([createdAt])
  // Compound: list user reports ordered by date (listReports endpoint)
  @@index([userId, createdAt])
  @@map("resume_check_reports")
}

/// Portfolio project — part of Career Studio public profile.
/// Phase 21 adds structured case study fields: slug, clientName, summary, problem, solution, impact,
/// responsibilities, mediaUrls, projectType, seoTitle, seoDescription.
model PortfolioProject {
  id               String                      @id @default(uuid()) @db.Uuid
  userId           String                      @db.Uuid
  careerProfileId  String                      @db.Uuid
  studentId        String?                     @db.Uuid
  title            String                      @db.VarChar(500)
  slug             String?                     @db.VarChar(200)
  role             String?                     @db.VarChar(255)
  clientName       String?                     @db.VarChar(200)
  description      String?                     @db.Text
  summary          String?                     @db.Text
  problem          String?                     @db.Text
  solution         String?                     @db.Text
  impact           String?                     @db.Text
  responsibilities Json?
  technologies     Json                        @default("[]")
  links            Json?
  images           Json?
  mediaUrls        Json?
  caseStudy        Json?
  startDate        DateTime?                   @db.Timestamptz
  endDate          DateTime?                   @db.Timestamptz
  projectType      String?                     @db.VarChar(100)
  visibility       PortfolioProjectVisibility  @default(PRIVATE)
  sortOrder        Int                         @default(0)
  isFeatured       Boolean                     @default(false)
  coverImageUrl    String?                     @db.VarChar(500)
  demoUrl          String?                     @db.VarChar(500)
  repoUrl          String?                     @db.VarChar(500)
  seoTitle         String?                     @db.VarChar(255)
  seoDescription   String?                     @db.VarChar(500)
  createdAt        DateTime                    @default(now()) @db.Timestamptz
  updatedAt        DateTime                    @updatedAt @db.Timestamptz
  deletedAt        DateTime?                   @db.Timestamptz

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerProfile   CareerProfile @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([careerProfileId])
  @@index([visibility])
  @@index([sortOrder])
  @@index([isFeatured])
  @@index([deletedAt])
  @@index([slug])
  // Compound: public profile query — filter by profile + visibility + not-deleted
  @@index([careerProfileId, visibility, deletedAt])
  @@map("portfolio_projects")
}

/// Career roadmap definition — e.g. Frontend Developer Roadmap.
model Roadmap {
  id          String        @id @default(uuid()) @db.Uuid
  title       String        @db.VarChar(500)
  slug        String        @unique @db.VarChar(255)
  description String?       @db.Text
  language    ResumeLanguage @default(FA_EN)
  status      RoadmapStatus  @default(DRAFT)
  metadata    Json?
  createdAt   DateTime      @default(now()) @db.Timestamptz
  updatedAt   DateTime      @updatedAt @db.Timestamptz

  nodes       RoadmapNode[]

  @@index([status])
  @@index([language])
  @@map("roadmaps")
}

/// A node inside a career roadmap (skill, topic, milestone, resource).
model RoadmapNode {
  id          String          @id @default(uuid()) @db.Uuid
  roadmapId   String          @db.Uuid
  title       String          @db.VarChar(500)
  description String?         @db.Text
  type        RoadmapNodeType @default(TOPIC)
  sortOrder   Int             @default(0)
  parentId    String?         @db.Uuid
  metadata    Json?
  createdAt   DateTime        @default(now()) @db.Timestamptz
  updatedAt   DateTime        @updatedAt @db.Timestamptz

  roadmap     Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  parent      RoadmapNode?    @relation("RoadmapNodeParent", fields: [parentId], references: [id])
  children    RoadmapNode[]   @relation("RoadmapNodeParent")

  @@index([roadmapId])
  @@index([parentId])
  @@index([type])
  @@index([sortOrder])
  @@map("roadmap_nodes")
}

/// Job match report — compare a resume against a job description.
model JobMatchReport {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  careerProfileId    String   @db.Uuid
  resumeDocumentId   String?  @db.Uuid
  // Phase 18.3 — source tracking for external resumes
  sourceType         String   @default("IRNO_RESUME") @db.VarChar(50)
  sourceFileName     String?  @db.VarChar(500)
  sourceTextSnapshot String?  @db.Text
  targetRole         String?  @db.VarChar(200)
  jobTitle           String?  @db.VarChar(500)
  jobDescription     String   @db.Text
  overallScore       Int?
  keywordScore       Int?
  skillGap           Json?
  recommendations    Json?
  createdAt          DateTime @default(now()) @db.Timestamptz

  user             User            @relation(fields: [userId], references: [id])
  careerProfile    CareerProfile   @relation(fields: [careerProfileId], references: [id], onDelete: Cascade)
  resumeDocument   ResumeDocument? @relation(fields: [resumeDocumentId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([careerProfileId])
  @@index([resumeDocumentId])
  @@index([sourceType])
  @@index([createdAt])
  // Compound: list user job match reports ordered by date (listJobMatchReports endpoint)
  @@index([careerProfileId, createdAt])
  @@map("job_match_reports")
}
