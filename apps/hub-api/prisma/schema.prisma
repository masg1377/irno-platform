  APPLICANT_STATUS_CHANGED
  APPLICANT_NOTE_ADDED
  APPLICANT_CONVERTED_TO_STUDENT
  STUDENT_CREATED
  STUDENT_NOTE_ADDED
  STUDENT_STATUS_CHANGED
  // Phase 5: Finance events
  ENROLLMENT_CREATED
  ENROLLMENT_STATUS_CHANGED
  PAYMENT_RECORDED
  PAYMENT_COMPLETED
  INSTALLMENT_CREATED
  INSTALLMENT_OVERDUE
  INSTALLMENT_PAID
  // Phase 6: extended events
  INSTALLMENT_WAIVED
  SYSTEM_NOTE
  // Phase 9: Meetino integration
  MEETINO_SESSION_ATTENDED
  MEETINO_SESSION_MISSED
  // Phase 12: Skills & Credits
  SKILL_AWARDED
  SKILL_UPDATED
  CREDIT_AWARDED
  CREDIT_REVOKED
  CREDIT_EXPIRED
  // Phase 13: Certificates
