/// An official certificate issued to a student by Irno.
model StudentCertificate {
  id                  String                        @id @default(uuid()) @db.Uuid
  studentId           String                        @db.Uuid
  templateId          String?                       @db.Uuid
  title               String                        @db.VarChar(500)
  certificateNumber   String                        @unique @db.VarChar(100)
  type                CertificateTemplateType
  status              StudentCertificateStatus      @default(ACTIVE)
  issuedAt            DateTime                      @default(now()) @db.Timestamptz
  expiresAt           DateTime?                     @db.Timestamptz
  sourceType          StudentCertificateSourceType?
  sourceId            String?                       @db.Uuid
  issuedById          String                        @db.Uuid
  verificationCode    String                        @unique @db.VarChar(100)
  publicVerifyEnabled Boolean                       @default(true)
  metadata            Json?
  createdAt           DateTime                      @default(now()) @db.Timestamptz
  updatedAt           DateTime                      @updatedAt @db.Timestamptz
  revokedAt           DateTime?                     @db.Timestamptz
