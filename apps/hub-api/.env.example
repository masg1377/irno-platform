# ─────────────────────────────────────────────────────────────────────
# irno-platform — Hub API environment example
# Copy to apps/hub-api/.env and fill in values for local dev.
#
# Local ports:
#   Hub Web:      http://localhost:3000
#   Hub API:      http://localhost:4000  ← this app
#   Meetino Web:  http://localhost:3001
#   Meetino API:  http://localhost:4001
#   PostgreSQL:   localhost:5433  (database: irno_hub)
#   Redis:        localhost:6380
# ─────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
# ⚠️  Plural key — API_CORS_ORIGINS (not API_CORS_ORIGIN). Wrong key silently breaks all cross-origin requests.
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ── Database ──────────────────────────────────────────────────
# PostgreSQL runs in Docker on host port 5433 (database: irno_hub)
# ⚠️  Replace CHANGE_ME_DB_PASSWORD with a strong random password in production.
DATABASE_URL=postgresql://irno:CHANGE_ME_DB_PASSWORD@localhost:5433/irno_hub?schema=public

# ── Redis ─────────────────────────────────────────────────────
# Redis runs in Docker on host port 6380
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# ⚠️  Generate unique secrets: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_openssl_rand_hex_32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Meetino Integration (Phase 9) ─────────────────────────────
# Set MEETINO_ENABLED=true and fill in URLs/keys to activate server-to-server
# API integration. Hub still allows manual Meetino link entry when disabled.
MEETINO_ENABLED=false
MEETINO_WEB_URL=http://localhost:3001
MEETINO_API_URL=http://localhost:4001
# MEETINO_API_KEY=<bearer-token-for-meetino-service-account>
# MEETINO_API_SECRET=
# MEETINO_WEBHOOK_SECRET=
MEETINO_OPEN_IN_NEW_TAB=true

# ── Meetino SSO / Irno ID Handoff (Phase 9.1) ────────────────
# Shared secret between Hub and Meetino for server-to-server SSO code exchange.
# Must be at least 32 chars. Generate with: openssl rand -hex 32
# This value must ALSO be set as IRNO_HUB_CLIENT_SECRET in meetino-api .env.
# NEVER expose this to the browser.
MEETINO_CLIENT_SECRET=change_me_to_a_long_random_secret_min_32_chars_shared_with_meetino

# Lifetime of the one-time SSO code in seconds (default: 60, max: 300)
MEETINO_SSO_CODE_TTL_SECONDS=60

# Allowed Meetino callback URL(s) for SSO redirect validation (comma-separated)
# Local dev: Meetino web runs on 3001
MEETINO_ALLOWED_REDIRECT_URLS=http://localhost:3001/auth/irno/callback
# Production: MEETINO_ALLOWED_REDIRECT_URLS=https://meet.irno.ir/auth/irno/callback
