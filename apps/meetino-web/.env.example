# ─────────────────────────────────────────────────────────────────────
# irno-platform — Meetino web environment example
# Copy to apps/meetino-web/.env.local and fill in values for local dev.
#
# Local ports:
#   Meetino Web:  http://localhost:3001  ← this app
#   Meetino API:  http://localhost:4001
#   LiveKit:      ws://localhost:7880
#   Hub Web:      http://localhost:3000  (for SSO redirect)
# ─────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────
# NEXT_PUBLIC_* values are sent to the browser — no secrets here.
NEXT_PUBLIC_API_URL=http://localhost:4001/api
NEXT_PUBLIC_APP_NAME=Meetino

# WebSocket URL for the Meetino API (socket.io realtime)
# Leave blank to derive from NEXT_PUBLIC_API_URL (strips trailing /api)
NEXT_PUBLIC_WS_URL=

# ── LiveKit ───────────────────────────────────────────────────
# Public LiveKit WS URL for the browser media connection
NEXT_PUBLIC_LIVEKIT_URL=ws://localhost:7880

# ── Irno ID / SSO (Phase 9.1 / 9.2) ─────────────────────────
# Set to true to show "ورود با حساب ایرنو" button in Meetino login/register
NEXT_PUBLIC_IRNO_SSO_ENABLED=false

# Irno ID base URL — where /auth/login, /auth/register, /sso/meetino live.
# This is the Hub web URL (Hub implements Irno ID Hosted UI).
# Used by @irno/auth-client to build login/register/SSO URLs.
# Canonical name: NEXT_PUBLIC_IRNO_ID_URL
NEXT_PUBLIC_IRNO_ID_URL=http://localhost:3000
# Legacy alias — kept for backward compat; prefer NEXT_PUBLIC_IRNO_ID_URL
NEXT_PUBLIC_IRNO_HUB_WEB_URL=http://localhost:3000

# Meetino app identifier (used as ?app= param in Hub auth URLs)
NEXT_PUBLIC_MEETINO_APP_ID=meetino

# Meetino SSO callback URL — where Hub redirects after generating the SSO code.
# Must match an entry in hub-api MEETINO_ALLOWED_REDIRECT_URLS.
NEXT_PUBLIC_MEETINO_CALLBACK_URL=http://localhost:3001/auth/irno/callback
