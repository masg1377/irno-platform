# Web-only env reference for production.
#
# IMPORTANT: NEXT_PUBLIC_* values are baked into the static JS at build
# time. Changing one requires rebuilding the web image — `docker compose
# build web` and then restarting it.

NEXT_PUBLIC_API_URL=https://api.meetino.example.com/api
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.meetino.example.com
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_APP_NAME=Meetino
