# ─────────────────────────────────────────────────────────────────────
# irno-platform — Meetino API environment example
# Copy to apps/meetino-api/.env and fill in values for local dev.
#
# Local ports:
#   Hub Web:      http://localhost:3000
#   Hub API:      http://localhost:4000
#   Meetino Web:  http://localhost:3001
#   Meetino API:  http://localhost:4001  ← this app
#   PostgreSQL:   localhost:5433  (shared container, database: meetino_db)
#   Redis:        localhost:6380  (shared container)
#   LiveKit:      ws://localhost:7880
# ─────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=4001
API_HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────
# PostgreSQL runs in Docker on host port 5433 (database: meetino_db)
DATABASE_URL=postgresql://irno:irno_secret@localhost:5433/meetino_db?schema=public

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ── CORS ──────────────────────────────────────────────────────
# Meetino web origin (NOT Hub web — these are separate apps)
WEB_ORIGIN=http://localhost:3001

# ── Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Use DIFFERENT secrets from Hub API — tokens must not be cross-accepted
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_string_32chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── LiveKit (self-hosted SFU) ─────────────────────────────────
# Must match the keys: block in infra/docker/livekit/livekit.yaml
# API_SECRET must be at least 32 chars.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=meetino_dev_only_secret_change_me_for_prod_min32chars_abcdef
# WS URL the backend returns to clients — ws:// for local, wss:// for prod
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_TOKEN_TTL_MINUTES=360

# ── Irno Hub SSO / Irno ID handoff (Phase 9.1) ───────────────
# Set IRNO_HUB_SSO_ENABLED=true to activate Hub identity integration.
IRNO_HUB_SSO_ENABLED=false
# Hub API URL for server-to-server SSO code exchange (never exposed to browser)
IRNO_HUB_API_URL=http://localhost:4000
# Hub web URL — where Meetino redirects users for Hub login
IRNO_HUB_WEB_URL=http://localhost:3000
# Shared secret — must match MEETINO_CLIENT_SECRET in hub-api .env
# Generate with: openssl rand -hex 32  (min 32 chars)
IRNO_HUB_CLIENT_SECRET=change_me_to_a_long_random_secret_min_32_chars_shared_with_hub
