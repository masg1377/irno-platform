# Meetino API — production environment example
# In docker-compose.prod.yml, Meetino API receives secrets from infra/docker/.env.prod.
# This file is for local prod-style runs (e.g. on a CI worker or standalone VPS without compose).
#
# Generate secrets with:  openssl rand -hex 32
# ⚠️  Never commit real secrets. Never use these placeholder values in production.

NODE_ENV=production
# ⚠️  Port must be 4001 in production (hub-api already uses 4000).
API_PORT=4001
API_HOST=0.0.0.0

# ── Database ──────────────────────────────────────────────────────────────────
# Reach Docker-network hostnames if running inside compose, or 127.0.0.1 on host.
# ⚠️  Replace the password with: openssl rand -hex 32
DATABASE_URL=postgresql://meetino:GENERATE_WITH__openssl_rand_hex_32@postgres:5432/meetino?schema=public
REDIS_URL=redis://:GENERATE_WITH__openssl_rand_hex_32@redis:6379

WEB_ORIGIN=https://meet.irnocollege.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate each secret independently: openssl rand -hex 32
JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32__use_a_different_value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── LiveKit ───────────────────────────────────────────────────────────────────
# LiveKit API key and secret are created in your LiveKit Cloud / self-hosted dashboard.
# API key is typically a short identifier; secret is generated with: openssl rand -hex 32
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=GENERATE_WITH__openssl_rand_hex_32
# ⚠️  LiveKit URL must point to the dedicated LiveKit domain, NOT the Meetino web domain.
LIVEKIT_URL=wss://livekit.irnocollege.com
LIVEKIT_TOKEN_TTL_MINUTES=360

# ── Irno Hub SSO Integration ──────────────────────────────────────────────────
# Must match MEETINO_CLIENT_SECRET in hub-api .env.
# Generate with: openssl rand -hex 32
IRNO_HUB_CLIENT_SECRET=GENERATE_WITH__openssl_rand_hex_32
IRNO_HUB_SSO_ENABLED=false
# Server-to-server: use internal Docker service name — never the public URL
IRNO_HUB_API_URL=http://hub-api:4000
IRNO_HUB_WEB_URL=https://platform.irnocollege.com
NEXT_PUBLIC_IRNO_SSO_ENABLED=false
NEXT_PUBLIC_IRNO_HUB_WEB_URL=https://platform.irnocollege.com

# ── Meeting Limits ────────────────────────────────────────────────────────────
# Sized for class sessions on a 4 GB VPS. Increase after hardware upgrade.
MEETING_MAX_PARTICIPANTS=10

# ── File Storage ──────────────────────────────────────────────────────────────
MEDIA_UPLOAD_DIR=/app/apps/api/storage/meeting-files
MEDIA_MAX_FILE_BYTES=26214400
