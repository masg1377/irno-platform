# API-only env reference for production.
# In docker-compose.prod.yml the API receives its env from the root
# `.env.production` (via --env-file). This file is for local prod-style
# runs (e.g. on a CI worker) where the API process reads its own .env.

NODE_ENV=production
API_PORT=4000
API_HOST=0.0.0.0

# Reach the docker-network hostnames if running inside compose, or
# 127.0.0.1 when running on the host.
DATABASE_URL=postgresql://meetino:CHANGE_ME@postgres:5432/meetino?schema=public
REDIS_URL=redis://redis:6379

WEB_ORIGIN=https://meetino.example.com

JWT_ACCESS_SECRET=CHANGE_ME_64HEX
JWT_REFRESH_SECRET=CHANGE_ME_64HEX_DIFFERENT
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=CHANGE_ME_64HEX_LIVEKIT
LIVEKIT_URL=wss://livekit.meetino.example.com
LIVEKIT_TOKEN_TTL_MINUTES=360

MEDIA_UPLOAD_DIR=/app/apps/api/storage/meeting-files
MEDIA_MAX_FILE_BYTES=26214400
