# ─────────────────────────────────────────────────────────────────────────────
# LiveKit production configuration — EXAMPLE / TEMPLATE
#
# Copy to /opt/irno/secrets/livekit.prod.yaml on the server.
# Set correct permissions:
#   chmod 0600 /opt/irno/secrets/livekit.prod.yaml
#   chown root:root /opt/irno/secrets/livekit.prod.yaml
#
# Replace LIVEKIT_API_KEY_PLACEHOLDER and LIVEKIT_API_SECRET_PLACEHOLDER with
# the values set in infra/docker/.env.prod (generated by first-deploy.sh).
#
# ⚠️  Do NOT commit the real livekit.prod.yaml to the repository.
#     /opt/irno/secrets/ is outside the repo root — never checked into git.
# ─────────────────────────────────────────────────────────────────────────────

port: 7880
log_level: info
bind_addresses:
  - ""

rtc:
  tcp_port: 7881
  udp_port: 7882
  use_external_ip: true
  # Do NOT set port_range_start / port_range_end when udp_port is specified —
  # they conflict and LiveKit will emit a config warning or ignore one of them.

turn:
  enabled: false

logging:
  level: info
  json: false

# ── API keys ──────────────────────────────────────────────────────────────────
# Format: key: secret  (one entry per key pair)
# Replace the placeholders below with the values from .env.prod:
#   LIVEKIT_API_KEY    → key   (left side of the colon)
#   LIVEKIT_API_SECRET → secret (right side of the colon)
#
# Example (do NOT use these values):
#   APIirno2026: a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6
keys:
  LIVEKIT_API_KEY_PLACEHOLDER: LIVEKIT_API_SECRET_PLACEHOLDER
