# Irno Platform production compose env example
# Copy to:
#   infra/docker/.env.prod
#
# Then verify with:
#   docker compose --env-file infra/docker/.env.prod \
#     -f infra/docker/docker-compose.prod.yml config
#
# ⚠️  Never commit real secrets.
# Generate every secret with:
#   openssl rand -hex 32

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=irno
POSTGRES_PASSWORD=GENERATE_WITH__openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=GENERATE_WITH__openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Hub API / Irno ID
# -----------------------------------------------------------------------------
HUB_JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
HUB_JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32
REFRESH_TOKEN_TTL=7d

SUPER_ADMIN_MOBILE=09xxxxxxxxx
SUPER_ADMIN_EMAIL=admin@irnocollege.com
SUPER_ADMIN_PASSWORD=GENERATE_STRONG_PASSWORD_BEFORE_FIRST_SEED

# -----------------------------------------------------------------------------
# OTP
# -----------------------------------------------------------------------------
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
NOTIFICATION_SMS_PROVIDER=mock

# -----------------------------------------------------------------------------
# PDF Export
# -----------------------------------------------------------------------------
PDF_EXPORT_ENABLED=true
# 1 Chromium process — appropriate for a 4 GB RAM VPS (~200 MB per Chromium page)
PDF_EXPORT_CONCURRENCY=1
PDF_EXPORT_QUEUE_MAX=3
PDF_EXPORT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Meetino integration from Hub
# -----------------------------------------------------------------------------
MEETINO_ENABLED=true
MEETINO_WEB_URL=https://meet.irnocollege.com
# Server-to-server: use internal Docker service name
MEETINO_API_URL=http://meetino-api:4001
# Shared secret for SSO exchange — must match IRNO_HUB_CLIENT_SECRET in meetino-api
MEETINO_CLIENT_SECRET=GENERATE_WITH__openssl_rand_hex_32
MEETINO_ALLOWED_REDIRECT_URLS=https://meet.irnocollege.com/auth/irno/callback
MEETINO_SSO_CODE_TTL_SECONDS=60
MEETINO_OPEN_IN_NEW_TAB=true

# -----------------------------------------------------------------------------
# Meetino API
# -----------------------------------------------------------------------------
MEETINO_JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
MEETINO_JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32

# SSO — set to true after both Hub and Meetino are live and MEETINO_CLIENT_SECRET
# is configured on both sides. Safe default is false for the first deploy.
IRNO_HUB_SSO_ENABLED=false

# Max concurrent participants per meeting room (10 suits most class sessions)
MEETING_MAX_PARTICIPANTS=10

# -----------------------------------------------------------------------------
# LiveKit
# -----------------------------------------------------------------------------
# API key: short alphanumeric identifier (e.g. APIirno2026 or a random hex prefix)
LIVEKIT_API_KEY=GENERATE_WITH__openssl_rand_hex_32
LIVEKIT_API_SECRET=GENERATE_WITH__openssl_rand_hex_32
# WebSocket URL used by:
#   - meetino-api (server-side token generation)
#   - meetino-web browser client (NEXT_PUBLIC_LIVEKIT_URL baked at build time by deploy.sh)
# Must point to the dedicated LiveKit WebSocket endpoint — NOT the Meetino web domain.
LIVEKIT_WS_URL=wss://livekit.irnocollege.com
