# Irno Platform production compose env example
# Copy this file to:
#   infra/docker/.env.prod
#
# Then run:
#   docker compose --env-file infra/docker/.env.prod -f infra/docker/docker-compose.prod.yml config
#
# Never commit real secrets.
# Generate secrets with:
#   openssl rand -hex 32

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=irno
POSTGRES_PASSWORD=GENERATE_WITH__openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=GENERATE_WITH__openssl_rand_hex_32

# -----------------------------------------------------------------------------
# Hub API / Irno ID
# -----------------------------------------------------------------------------
HUB_JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
HUB_JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32
REFRESH_TOKEN_TTL=7d

SUPER_ADMIN_MOBILE=09120000000
SUPER_ADMIN_EMAIL=admin@irno.ir
SUPER_ADMIN_PASSWORD=GENERATE_STRONG_PASSWORD_BEFORE_FIRST_SEED

# -----------------------------------------------------------------------------
# OTP
# -----------------------------------------------------------------------------
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
NOTIFICATION_SMS_PROVIDER=mock

# -----------------------------------------------------------------------------
# PDF Export
# -----------------------------------------------------------------------------
PDF_EXPORT_ENABLED=true
PDF_EXPORT_CONCURRENCY=1
PDF_EXPORT_QUEUE_MAX=5
PDF_EXPORT_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Meetino integration from Hub
# -----------------------------------------------------------------------------
MEETINO_ENABLED=false
MEETINO_WEB_URL=https://meet.irno.ir
MEETINO_API_URL=https://meet.irno.ir
MEETINO_CLIENT_SECRET=GENERATE_WITH__openssl_rand_hex_32
MEETINO_ALLOWED_REDIRECT_URLS=https://meet.irno.ir/auth/irno/callback
MEETINO_SSO_CODE_TTL_SECONDS=60
MEETINO_OPEN_IN_NEW_TAB=true

# -----------------------------------------------------------------------------
# Meetino API
# -----------------------------------------------------------------------------
MEETINO_JWT_ACCESS_SECRET=GENERATE_WITH__openssl_rand_hex_32
MEETINO_JWT_REFRESH_SECRET=GENERATE_WITH__openssl_rand_hex_32

IRNO_HUB_SSO_ENABLED=false

MEETING_MAX_PARTICIPANTS=100

# -----------------------------------------------------------------------------
# LiveKit
# -----------------------------------------------------------------------------
LIVEKIT_API_KEY=GENERATE_WITH__openssl_rand_hex_32
LIVEKIT_API_SECRET=GENERATE_WITH__openssl_rand_hex_32
LIVEKIT_WS_URL=wss://meet.irno.ir